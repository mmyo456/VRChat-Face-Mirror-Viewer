<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="BG" style="width: 100%; height: 100%; justify-content: center; align-items: center; padding-left: 8px; padding-right: 8px; padding-top: 8px; padding-bottom: 8px;">
        <ui:VisualElement name="Scaled" style="position: absolute; width: 100%; height: 100%; background-color: rgb(0, 0, 0);"/>
        <ui:ScrollView name="UnscaledScroll" vertical-scroller-visibility="Hidden" style="position: absolute; width: 100%; height: 100%; background-color: rgb(0, 0, 0);">
            <ui:VisualElement name="Unscaled"/>
        </ui:ScrollView>
        <ui:VisualElement name="ControlPanel" style="width: 90%; max-width: 524px; max-height: 90%; padding-left: 8px; padding-right: 8px; padding-top: 8px; padding-bottom: 4px; background-color: rgb(178, 178, 178); border-bottom-left-radius: 4px; border-bottom-right-radius: 4px; border-bottom-width: 1px; border-bottom-color: rgb(26, 26, 26); opacity: 0.7; align-items: stretch; justify-content: flex-end; flex-direction: column;">
            <ui:ScrollView horizontal-scroller-visibility="Hidden" vertical-scroller-visibility="Auto" style="max-height: 100%;">
                <ui:DropdownField label="Spout 源" index="-1" choices="0,1" name="SpoutNames" style="width: 100%;"/>
                <ui:Toggle label="缩放到屏幕" name="TexScale"/>
                <ui:Toggle label="镜像画面" name="Mirror"/>
                <ui:Toggle label="全屏画面" name="FullScreen"/>
                <ui:Toggle label="窗口置顶" name="TopMost"/>
                <ui:Button text="保存纹理" display-tooltip-when-elided="true"/>
            </ui:ScrollView>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>

